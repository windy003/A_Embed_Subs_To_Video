<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_light">

    <!-- 顶部标题栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:title="字幕精灵"
        android:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- 图标区域 -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                android:src="@android:drawable/ic_menu_slideshow"
                android:contentDescription="视频图标"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="视频语音转字幕工具"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="导入视频 → Whisper 识别 → 编辑字幕 → 导出成品"
                android:textSize="14sp"
                android:textColor="@color/gray_dark"
                android:gravity="center" />

            <!-- API Key 卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Whisper 语音识别"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="API Key 仅存储在本机，支持多种服务商"
                        android:textSize="12sp"
                        android:textColor="@color/gray_dark" />

                    <!-- 服务商选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="服务商"
                        android:textSize="13dp"
                        android:textColor="@color/black" />

                    <Spinner
                        android:id="@+id/spinnerProvider"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_edit_text"
                        android:paddingHorizontal="12dp"
                        android:gravity="center_vertical" />

                    <!-- 自定义 API 地址（仅自定义模式可见） -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutCustomUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="API 地址"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCustomUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:textSize="13sp"
                            android:text="https://"
                            android:importantForAutofill="no" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- API Key -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:endIconMode="password_toggle"
                        android:hint="API Key">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="14sp"
                            android:importantForAutofill="no" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 语言选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="识别语言"
                        android:textSize="13dp"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLangAuto"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="自动"
                            android:textSize="12dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLangZh"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="中文"
                            android:textSize="12dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLangYue"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="粤语"
                            android:textSize="12dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLangEn"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="英文"
                            android:textSize="12dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="4dp" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 选择视频按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectVideo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="选择视频文件"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart" />

            <!-- 已选视频信息 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVideoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvVideoName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="video.mp4"
                        android:textSize="15sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/tvVideoSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="12sp"
                        android:textColor="@color/gray_dark" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartRecognize"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="开始识别语音"
                        android:textSize="15sp"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 进度区域 -->
            <LinearLayout
                android:id="@+id/layoutProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:trackCornerRadius="4dp" />

                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="处理中..."
                    android:textSize="14sp"
                    android:textColor="@color/gray_dark" />

            </LinearLayout>

            <!-- 错误提示 -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="#FFEBEE"
                android:textColor="@color/error_red"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
